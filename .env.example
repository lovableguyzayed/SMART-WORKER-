# GEMINI_API_KEY: Required for Gemini AI API calls.
# This is a placeholder key.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY=MY_GEMINI_API_KEY

# ── Cloud sync (optional) ─────────────────────────────────────────────────
# The app is fully offline-first and works without these. When both values
# are set (copy this file to .env and fill them in), the app automatically
# pushes local changes to your Supabase project in the background and the
# APK ships pre-configured -- users never enter server details.
# SUPABASE_URL example: https://abcdefghij.supabase.co
SUPABASE_URL=
SUPABASE_ANON_KEY=
